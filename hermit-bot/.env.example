# The Hermit Bot Configuration
# Copy to .env and fill in values

# Anthropic API key for LLM responses
ANTHROPIC_API_KEY=sk-ant-...

# LLM model to use (haiku is fast & cheap for chat)
LLM_MODEL=claude-haiku-4-5-20251001

# y-websocket relay server URL
WS_URL=ws://localhost:4445

# Room to join (matches URL hash format: "room-name" or "room-name:model_key")
ROOM_NAME=model-a

# Rate limiting
MAX_MSG_PER_MIN=5
POLL_INTERVAL=5
